@using SpellBrigadeCalculator.Engine
@using SpellBrigadeCalculator.Engine.Spells

<div class="spell-slot">
    <label>@Label</label>

    @if (IsSignature)
    {
        <select class="spell-select" disabled value="@SpellSlot.Spell?.Name">
            @foreach (var spell in AvailableSpells)
            {
                <option value="@spell.Name">@spell.Name</option>
            }
        </select>
    }
    else
    {
        <select class="spell-select" value="@SpellSlot.Spell?.Name" @onchange="OnSpellChanged">
            <option value="">-- Choose --</option>
            @foreach (var spell in AvailableSpells)
            {
                <option value="@spell.Name">@spell.Name</option>
            }
        </select>
    }

    @if (SpellSlot.Spell != null)
    {
        <div class="spell-icon">
            <img src="@SpellSlot.Spell.ImagePath" alt="@SpellSlot.Spell.Name" />
        </div>

        <div class="current-damage">
            <span class="damage-label">Calculated DPS</span>
            <span class="damage-value">@CurrentDps.ToString("N1")</span>
        </div>

        <div class="upgrade-section">
            <div class="upgrade-columns">
                <div class="upgrade-group">
                    <span class="upgrade-title">Increase Spell Damage</span>
                    @foreach (var value in DamageUpgradeValues)
                    {
                        <div class="upgrade-row">
                            <button class="upgrade-btn" @onclick="() => AddDamageUpgrade(value)">
                                @value%
                            </button>
                            <span class="predicted-dps">+@GetDpsIncreasePercentWithDamage(value).ToString("F1")%</span>
                        </div>
                    }
                </div>

                <div class="upgrade-group">
                    <span class="upgrade-title">Increase Cast Speed</span>
                    @foreach (var value in CooldownUpgradeValues)
                    {
                        <div class="upgrade-row">
                            <button class="upgrade-btn" @onclick="() => AddCooldownUpgrade(value)">
                                @value%
                            </button>
                            <span class="predicted-dps">+@GetDpsIncreasePercentWithCooldown(value).ToString("F1")%</span>
                        </div>
                    }
                </div>

                <div class="spell-stats">
                    <div class="stat-row">
                        <span class="stat-label">Base Damage</span>
                        <span class="stat-value">@DpsDetails.BaseDamage</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Damage/Hit (Normal)</span>
                        <span class="stat-value">@DpsDetails.DamagePerHitNormal.ToString("N1")</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Damage/Hit (Crit)</span>
                        <span class="stat-value">@DpsDetails.DamagePerHitCrit.ToString("N1")</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Damage/Hit (Avg)</span>
                        <span class="stat-value">@DpsDetails.DamagePerHitAverage.ToString("N1")</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Projectiles</span>
                        <span class="stat-value">@DpsDetails.ProjectileCount</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Attacks / Sec</span>
                        <span class="stat-value">@DpsDetails.AttacksPerSecond.ToString("F2")</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Effective CD</span>
                        <span class="stat-value">@DpsDetails.EffectiveCooldown.ToString("F2")s</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Crit Chance</span>
                        <span class="stat-value">@TotalCritChance%</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Crit Damage</span>
                        <span class="stat-value">@TotalCritDamage%</span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public required string Label { get; set; }
    [Parameter] public required SpellSlot SpellSlot { get; set; }
    [Parameter] public required GameState GameState { get; set; }
    [Parameter] public bool IsSignature { get; set; }
    [Parameter] public IEnumerable<SpellBase> AvailableSpells { get; set; } = [];
    [Parameter] public EventCallback OnStateChanged { get; set; }

    private static readonly int[] DamageUpgradeValues = [10, 15, 25, 35];
    private static readonly int[] CooldownUpgradeValues = [10, 15, 25, 35];

    private SpellDpsDetails DpsDetails => DpsEngine.CalculateDpsDetails(GameState, SpellSlot);
    private double CurrentDps => DpsDetails.Dps;

    private int TotalCritChance
    {
        get
        {
            if (GameState.Wizard == null)
            {
                return 0;
            }

            var (_, _, casterPrecision, _) = GameState.GetGlobalUpgrades();
            return Math.Min(GameState.Wizard.IncreaseCriticalChance + casterPrecision + GameState.EnchantmentCritChancePercent, 100);
        }
    }

    private int TotalCritDamage
    {
        get
        {
            if (GameState.Wizard == null)
            {
                return 0;
            }

            var (_, _, _, wizardsEdge) = GameState.GetGlobalUpgrades();
            return GameState.Wizard.IncreaseBaseCriticalDamage + wizardsEdge + GameState.EnchantmentCritDamagePercent;
        }
    }

    private double GetDpsIncreasePercentWithDamage(int damageValue)
    {
        if (SpellSlot.Spell == null)
        {
            return 0;
        }

        var currentDps = DpsEngine.CalculateDps(GameState, SpellSlot);
        if (currentDps == 0)
        {
            return 0;
        }

        var upgrade = new Upgrade
        {
            Name = $"{SpellSlot.Spell.Name} Damage +{damageValue}%",
            SpellName = SpellSlot.Spell.Name,
            IncreaseSpellDamage = damageValue
        };
        var newDps = DpsEngine.CalculateDpsWithUpgrade(GameState, SpellSlot, upgrade);
        return (newDps - currentDps) / currentDps * 100;
    }

    private double GetDpsIncreasePercentWithCooldown(int cooldownValue)
    {
        if (SpellSlot.Spell == null)
        {
            return 0;
        }

        var currentDps = DpsEngine.CalculateDps(GameState, SpellSlot);
        if (currentDps == 0)
        {
            return 0;
        }

        var upgrade = new Upgrade
        {
            Name = $"{SpellSlot.Spell.Name} Cast Speed +{cooldownValue}%",
            SpellName = SpellSlot.Spell.Name,
            IncreaseCastSpeed = cooldownValue
        };
        var newDps = DpsEngine.CalculateDpsWithUpgrade(GameState, SpellSlot, upgrade);
        return (newDps - currentDps) / currentDps * 100;
    }

    private async Task OnSpellChanged(ChangeEventArgs e)
    {
        var spellName = e.Value?.ToString();
        SpellSlot.Spell = string.IsNullOrEmpty(spellName)
            ? null
            : AvailableSpells.FirstOrDefault(s => s.Name == spellName);
        await OnStateChanged.InvokeAsync();
    }

    private async Task AddDamageUpgrade(int value)
    {
        if (SpellSlot.Spell == null)
        {
            return;
        }

        GameState.AddUpgrade(new Upgrade
        {
            Name = $"{SpellSlot.Spell.Name} Damage +{value}%",
            SpellName = SpellSlot.Spell.Name,
            IncreaseSpellDamage = value
        });
        await OnStateChanged.InvokeAsync();
    }

    private async Task AddCooldownUpgrade(int value)
    {
        if (SpellSlot.Spell == null)
        {
            return;
        }

        GameState.AddUpgrade(new Upgrade
        {
            Name = $"{SpellSlot.Spell.Name} Cast Speed +{value}%",
            SpellName = SpellSlot.Spell.Name,
            IncreaseCastSpeed = value
        });
        await OnStateChanged.InvokeAsync();
    }
}
